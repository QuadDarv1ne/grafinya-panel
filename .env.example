# Графиня Панель управления — Переменные окружения

# URL сервера Графини (API backend)
NEXT_PUBLIC_GRAFINYA_URL=http://localhost:8000

# Секрет для JWT (если используется NextAuth)
# NEXTAUTH_SECRET=your-secret-here
# NEXTAUTH_URL=http://localhost:3000

# База данных (если используется Prisma)
# DATABASE_URL="postgresql://user:password@localhost:5432/grafinya?schema=public"

# Прокси API (внутренний)
API_PROXY_TARGET=http://localhost:8000
